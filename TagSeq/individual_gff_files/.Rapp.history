plot(y$logFC, -log10(y$adj.P.Val), xlab = "LFC", ylab = "-log10(FDR)", main = "Volcano plot sex DEGs")#
points(y[y$adj.P.Val < 0.05, ]$logFC, -log10(y[y$adj.P.Val < 0.05, ]$adj.P.Val), col = "blue")
y<-NULL
