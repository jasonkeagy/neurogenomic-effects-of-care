fontsize <- 24#
dodge_jitter <- 0.3#
dodge_stat <- 0.3#
#
# treatment:sex over 2 time periods#
figTrtXFreeze <- ggplot(data = mergedData[!(is.na(mergedData$SIDE.RNA)) & #
                          (mergedData$TimeBin == "before_1" | mergedData$TimeBin == "after_0"), ], #
  aes(x = Time.Period, y = propFreeze, color = Sex1, shape = Trt)) #
figTrtXFreeze <- figTrtXFreeze + scale_size_continuous(guide = FALSE) + #
  geom_point(aes(group = FishTankID), size = 1, alpha = 0.5, #
    position = position_dodge(width = dodge_jitter)) +#
  stat_summary(aes(y = propFreeze, group = Trt:Sex1), fun.y = mean, geom = "line",#
    position = position_dodge(width = dodge_stat)) +#
  stat_summary(aes(y = propFreeze, group = Trt:Sex1), fun.y = mean, #
    fun.ymin = meanminus, fun.ymax = meanplus, geom = "pointrange", size = 1.25, #
    position = position_dodge(width = dodge_stat), alpha = 0.9) + #
  ylab("Proportion Time Frozen in\nOpen Field Assay") + #
  xlab("Time Period") + #
  theme_bw() + #
  scale_color_discrete(name = "Sex") +#
  scale_shape_discrete(name = "Father\nRemoved") +#
  theme(axis.text = element_text(size = (fontsize * 0.75)),#
    axis.title = element_text(size = fontsize), #
    legend.text = element_text(size = (fontsize * 0.75)),#
    legend.title = element_text(size = fontsize))#
quartz(width = 8, height = 6)#
figTrtXFreeze
