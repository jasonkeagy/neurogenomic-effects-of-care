# some functions
se <- function(x) {
# standard standard error function
sd(x)/sqrt(length(x))
}
meanplus <- function(x) {
# returns mean plus standard error
mean(x) + se(x)
}
meanminus <- function(x) {
# returns mean minus standard error
mean(x) - se(x)
}
